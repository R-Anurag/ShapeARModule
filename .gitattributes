# Normalize line endings
* text=auto

# Unity YAML files
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.inputactions text eol=lf

# Binary files
*.fbx binary
*.obj binary
*.png binary
*.jpg binary
*.jpeg binary
*.apk binary
*.dll binary
*.pdb binary
